<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Amplyze ⚡"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#4A148C"
            android:padding="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monthly Electricity Bill Estimator"
            android:textSize="16sp"
            android:gravity="center"
            android:textColor="#555555"
            android:paddingBottom="15dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Month"
            android:textStyle="bold"
            android:textSize="16sp" />

        <Spinner
            android:id="@+id/spinnerMonth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            tools:ignore="TouchTargetSizeCheck" />

        <EditText
            android:id="@+id/etUnit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter unit used: 1 - 1000 kWh"
            android:inputType="number"
            android:layout_marginTop="15dp"
            android:padding="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Rebate Percentage"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="15dp" />

        <RadioGroup
            android:id="@+id/radioGroupRebate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton android:id="@+id/rb0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:checked="true"/>
            <RadioButton android:id="@+id/rb1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1%"/>
            <RadioButton android:id="@+id/rb2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2%"/>
            <RadioButton android:id="@+id/rb3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3%"/>
            <RadioButton android:id="@+id/rb4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4%"/>
            <RadioButton android:id="@+id/rb5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5%"/>

        </RadioGroup>

        <Button
            android:id="@+id/btnCalculateSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CALCULATE AND SAVE"
            android:layout_marginTop="20dp"
            android:backgroundTint="#6A1B9A"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please select a month, enter electricity usage and rebate percentage before calculating."
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESET"
            android:layout_marginTop="10dp"
            android:backgroundTint="#757575"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvTotalCharges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Charges: RM 0.00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/tvFinalCost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Final Cost: RM 0.00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnViewRecords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VIEW BILL RECORDS"
            android:layout_marginTop="25dp"
            android:backgroundTint="#00897B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ABOUT APP"
            android:layout_marginTop="10dp"
            android:backgroundTint="#3949AB"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>